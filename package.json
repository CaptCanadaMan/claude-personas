{
  "name": "claude-persona",
  "version": "0.1.0",
  "description": "Tunable character system for Claude Code. Personality dials and archetype presets compiled into hot-swappable output styles.",
  "type": "module",
  "scripts": {
    "setup": "node install.ts",
    "uninstall": "node install.ts --uninstall",
    "compile": "node src/compile.ts",
    "print": "node src/compile.ts --print",
    "test": "node --test",
    "check": "tsc --noEmit"
  },
  "keywords": [
    "claude",
    "claude-code",
    "persona",
    "personality",
    "output-styles",
    "system-prompt"
  ],
  "author": "Andrew Horsburgh (https://github.com/CaptCanadaMan)",
  "contributors": [
    "Claude (Anthropic) <noreply@anthropic.com> (https://claude.com/claude-code)"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CaptCanadaMan/claude-persona.git"
  },
  "bugs": {
    "url": "https://github.com/CaptCanadaMan/claude-persona/issues"
  },
  "homepage": "https://github.com/CaptCanadaMan/claude-persona#readme",
  "files": [
    "src/",
    "output-styles/",
    ".claude/",
    "install.ts",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=23.6.0"
  },
  "devDependencies": {
    "@types/node": "22.19.17",
    "typescript": "5.9.3"
  }
}
